# Copy this file to ".env" in the same folder as server.js (never commit .env).
#
# Server bind address (optional). Default 0.0.0.0 = accept LAN + ngrok. Use 127.0.0.1 to listen on localhost only.
# BIND_HOST=0.0.0.0
#
# Get a secret or restricted key from: https://dashboard.stripe.com/apikeys
# If your key was shared publicly, rotate it in the Dashboard first.
STRIPE_SECRET_KEY=

# Checkout currency: omit or "usd" (default). Only set to "xof" if your Stripe account supports XOF.
# STRIPE_CURRENCY=xof

# When using USD: FCFA shop total ÷ this number = USD charged (then ×100 for cents). Tune to match your FX (e.g. 600–720).
STRIPE_FCFA_PER_USD=600
